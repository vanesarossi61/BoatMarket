# ===========================================
# BOATMARKET - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BoatMarket
NODE_ENV=development

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://boatmarket:boatmarket@localhost:5432/boatmarket?schema=public

# --- Payload CMS ---
PAYLOAD_SECRET=your-payload-secret-min-32-chars-here
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# --- Auth (NextAuth.js v5) ---
AUTH_SECRET=your-nextauth-secret-min-32-chars-here
AUTH_URL=http://localhost:3000
# Google OAuth (optional)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Facebook OAuth (optional)
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# --- Cloudinary (Media) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# --- Meilisearch (Search) ---
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-master-key
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=your-meilisearch-search-key

# --- Redis (Cache and Sessions) ---
REDIS_URL=redis://localhost:6379

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Resend (Email) ---
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@boatmarket.com

# --- Mapbox (Maps) ---
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxx

# --- Analytics ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# --- Sentry (Error Tracking - optional) ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Rate Limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
