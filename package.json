    "next-themes": "^0.4.4",
    "nuqs": "^2.3.0",
    "payload": "^3.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.5",
    "react-hook-form": "^7.54.2",
    "react-map-gl": "^7.1.8",
    "recharts": "^2.15.0",
    "resend": "^4.1.0",
    "sharp": "^0.33.5",
    "slugify": "^1.6.6",
